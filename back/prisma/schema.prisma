generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model areas {
  id          Int          @id @default(autoincrement())
  area        String?      @db.VarChar(50)
  responsable String?      @db.VarChar(100)
  createdAt   DateTime?    @db.Date
  updatedAt   DateTime?    @db.Date
  impresoras  impresoras[]
}

model cartuchos {
  id                        Int                         @id @default(autoincrement())
  modelo                    String                      @db.VarChar(255)
  sku                       String?                     @unique(map: "sku") @db.VarChar(100)
  color                     String?                     @db.VarChar(50)
  tipo                      cartuchos_tipo
  es_recargable             Boolean                     @default(false)
  insumo_granel_id          Int?
  stock_unidades            Int                         @default(0)
  stock_minimo_unidades     Int                         @default(0)
  createdAt                 DateTime                    @default(now()) @db.DateTime(0)
  updatedAt                 DateTime                    @default(now()) @db.DateTime(0)
  insumos_granel            insumos_granel?             @relation(fields: [insumo_granel_id], references: [id], map: "fk_cartuchos_insumo_granel_id")
  movimientos_insumo_granel movimientos_insumo_granel[]
  movimientos_tinta         movimientos_tinta[]

  @@index([insumo_granel_id], map: "fk_cartuchos_insumo_granel_id")
}

model estados {
  id        Int       @id @default(autoincrement())
  estado    String?   @db.VarChar(20)
  createdAt DateTime? @db.Date
  updatedAt DateTime? @db.Date
}

model impresoras {
  id                        Int                         @id @default(autoincrement())
  modelo                    String                      @db.VarChar(255)
  marca                     String?                     @db.VarChar(100)
  area_id                   Int?
  createdAt                 DateTime                    @default(now()) @db.DateTime(0)
  updatedAt                 DateTime                    @default(now()) @db.DateTime(0)
  areas                     areas?                      @relation(fields: [area_id], references: [id], map: "fk_impresoras_areas")
  movimientos_insumo_granel movimientos_insumo_granel[]
  movimientos_tinta         movimientos_tinta[]

  @@index([area_id], map: "fk_impresoras_areas_idx")
}

model insumos_granel {
  id                        Int                          @id @default(autoincrement())
  nombre                    String                       @db.VarChar(255)
  sku                       String?                      @db.VarChar(255)
  unidad_medida             insumos_granel_unidad_medida
  stock_actual              Decimal                      @default(0.000) @db.Decimal(10, 3)
  stock_minimo              Decimal                      @default(0.000) @db.Decimal(10, 3)
  createdAt                 DateTime                     @db.DateTime(0)
  updatedAt                 DateTime                     @db.DateTime(0)
  cartuchos                 cartuchos[]
  movimientos_insumo_granel movimientos_insumo_granel[]
}

model inventarios {
  id             Int       @id @default(autoincrement())
  num_inventario String?   @db.VarChar(30)
  num_pc         String?   @db.VarChar(20)
  tipo           String?   @db.VarChar(50)
  descripcion    String?   @db.VarChar(200)
  marca          String?   @db.VarChar(50)
  num_serie      String?   @db.VarChar(50)
  observaciones  String?   @db.VarChar(200)
  area           String?   @db.VarChar(50)
  usuario        String?   @db.VarChar(30)
  resp_area      String?   @db.VarChar(50)
  estado         String?   @db.VarChar(50)
  createdAt      DateTime? @db.Date
  updatedAt      DateTime? @db.Date
}

model movimientos_insumo_granel {
  id                            Int            @id @default(autoincrement())
  insumo_granel_id              Int
  unidad_cartucho_id            Int?
  cantidad_usada                Decimal        @db.Decimal(10, 3)
  cantidad_cartuchos_recargados Int?
  usuario_id                    Int
  impresora_id                  Int?
  fecha                         DateTime       @db.DateTime(0)
  tipo_movimiento               String         @db.VarChar(255)
  createdAt                     DateTime       @db.DateTime(0)
  updatedAt                     DateTime       @db.DateTime(0)
  cartuchos                     cartuchos?     @relation(fields: [unidad_cartucho_id], references: [id], map: "fk_mov_granel_cartucho")
  insumos_granel                insumos_granel @relation(fields: [insumo_granel_id], references: [id], onDelete: NoAction, map: "fk_mov_granel_insumo")
  usuarios                      usuarios       @relation(fields: [usuario_id], references: [id], onDelete: NoAction, map: "fk_mov_granel_usuario")
  impresoras                    impresoras?    @relation(fields: [impresora_id], references: [id], map: "fk_movimiento_granel_impresora")

  @@index([unidad_cartucho_id], map: "fk_mov_granel_cartucho")
  @@index([insumo_granel_id], map: "fk_mov_granel_insumo")
  @@index([usuario_id], map: "fk_mov_granel_usuario")
  @@index([impresora_id], map: "fk_movimiento_granel_impresora")
}

model movimientos_tinta {
  id              Int                               @id @default(autoincrement())
  cartucho_id     Int
  impresora_id    Int?
  fecha           DateTime                          @db.DateTime(0)
  tipo_movimiento movimientos_tinta_tipo_movimiento
  cantidad        Int
  usuario_id      Int?
  createdAt       DateTime                          @default(now()) @db.DateTime(0)
  updatedAt       DateTime                          @default(now()) @db.DateTime(0)
  cartuchos       cartuchos                         @relation(fields: [cartucho_id], references: [id], map: "fk_movimientos_cartuchos")
  impresoras      impresoras?                       @relation(fields: [impresora_id], references: [id], map: "fk_movimientos_impresoras")
  usuarios        usuarios?                         @relation(fields: [usuario_id], references: [id], map: "fk_movimientos_users")

  @@index([cartucho_id], map: "fk_movimientos_cartuchos_idx")
  @@index([impresora_id], map: "fk_movimientos_impresoras_idx")
  @@index([usuario_id], map: "fk_movimientos_users_idx")
}

model ordendeservicios {
  id                 Int       @id @default(autoincrement())
  id_equipo          String?   @db.VarChar(20)
  fecha_recepcion    DateTime? @db.DateTime(0)
  fecha_entrega      DateTime? @db.DateTime(0)
  problema_reportado String?   @db.VarChar(255)
  trabajo_realizado  String?   @db.VarChar(255)
  tecnico_asignado   String?   @db.VarChar(255)
  estado             String?   @db.VarChar(255)
  createdAt          DateTime  @db.DateTime(0)
  updatedAt          DateTime  @db.DateTime(0)
}

model tipos {
  id        Int       @id @default(autoincrement())
  tipo      String?   @db.VarChar(50)
  createdAt DateTime? @db.Date
  updatedAt DateTime? @db.Date
}

model usuarios {
  id                        Int                         @default(autoincrement()) @unique
  nombre                    String?                     @db.VarChar(100)
  apellido                  String?                     @db.VarChar(100)
  usuario                   String                      @id @db.VarChar(50)
  password                  String?                     @db.VarChar(30)
  createdAt                 DateTime?                   @db.Date
  updatedAt                 DateTime?                   @db.Date
  movimientos_insumo_granel movimientos_insumo_granel[]
  movimientos_tinta         movimientos_tinta[]

  @@index([id], map: "id")
}

enum insumos_granel_unidad_medida {
  kg
  g
  l
  ml
}

enum movimientos_tinta_tipo_movimiento {
  ENTREGA_A__REA       @map("ENTREGA A ÁREA")
  COMPRA
  AJUSTE_DE_INVENTARIO @map("AJUSTE DE INVENTARIO")
}

enum cartuchos_tipo {
  Toner
  Tinta
  Drum
}
